@{
    ViewBag.Title = "Risk Assessment Report";

    //check admin privileges
    var adminRole = ELG.Web.Helper.SessionHelper.UserRole;
    if (adminRole > 0)
    {
        Layout = ELG.Web.Helper.CommonHelper.GetAdminLayoutPage(adminRole);
    }
    else
    {
        <div class="alert alert-danger">Unauthorized access. Please <a href="@Url.Action("LogOut", "Account")">log out</a>.</div>
    }
}

<div class="ra-modern-page">
    <header class="ra-hero">
        <div>
            <nav class="ra-breadcrumb" aria-label="breadcrumb">
                <a href="@Url.Action("InsightsReports", "Report")">Reports &amp; Analytics</a>
                <span>/</span>
                <span>Risk Assessment Report</span>
            </nav>
            <h1 class="ra-title">Risk Assessments</h1>
            <p class="ra-subtitle">Review completion, issue flags, and sign-off status across assigned assessments.</p>
        </div>
        <a href="@Url.Action("InsightsReports", "Report")" class="ra-back-btn">
            <i class="fa fa-arrow-left"></i>
            Back to Reports
        </a>
    </header>

    <section class="ra-filter-card">
        <div class="row g-3 align-items-end">
            <div class="col-lg-2 col-md-4 col-sm-6">
                <label class="form-label ra-label" for="txtLearner">User</label>
                <div class="input-group ra-input-group">
                    <span class="input-group-text"><i class="fa fa-search"></i></span>
                    <input type="text" id="txtLearner" class="form-control" placeholder="Name or email">
                </div>
            </div>

            <div class="col-lg-2 col-md-4 col-sm-6">
                <label class="form-label ra-label" for="ddlLocation">@ELG.Web.Helper.SessionHelper.CompanySettings.strLocationDescription</label>
                <select id="ddlLocation" class="form-select ddl-loc">
                    <option value="0">Select All</option>
                </select>
            </div>

            <div class="col-lg-2 col-md-4 col-sm-6">
                <label class="form-label ra-label" for="ddlDepartment">@ELG.Web.Helper.SessionHelper.CompanySettings.strDepartmentDescription</label>
                <select id="ddlDepartment" class="form-select ddl-dep">
                    <option value="0">Select All</option>
                </select>
            </div>

            <div class="col-lg-2 col-md-4 col-sm-6">
                <label class="form-label ra-label" for="ddlCourse">Risk Assessment</label>
                <select id="ddlCourse" class="form-select ddl-course">
                    <option value="0">Select All</option>
                </select>
            </div>

            <div class="col-lg-2 col-md-4 col-sm-6">
                <label class="form-label ra-label" for="ddlRAStatus">Status</label>
                <select id="ddlRAStatus" class="form-select">
                    <option value="0" selected>Select All</option>
                    <option value="1">Completed</option>
                    <option value="2">Not complete</option>
                </select>
            </div>

            <div class="col-lg-2 col-md-4 col-sm-6">
                <label class="form-label ra-label" for="ddlIssue">Issue</label>
                <select id="ddlIssue" class="form-select">
                    <option value="0" selected>Select All</option>
                    <option value="1">Yes</option>
                    <option value="2">No</option>
                </select>
            </div>
        </div>

        <div class="row g-3 align-items-end mt-1">
            <div class="col-lg-2 col-md-4 col-sm-6">
                <label class="form-label ra-label" for="ddlSignedOff">Signed Off</label>
                <select id="ddlSignedOff" class="form-select">
                    <option value="0" selected>Select All</option>
                    <option value="1">Yes</option>
                    <option value="2">No</option>
                </select>
            </div>

            <div class="col-lg-3 col-md-4 col-sm-6">
                <label class="form-label ra-label" for="txtRptFrom">Completed From</label>
                <input type="text" id="txtRptFrom" class="form-control" placeholder="yyyy-mm-dd">
            </div>

            <div class="col-lg-3 col-md-4 col-sm-6">
                <label class="form-label ra-label" for="txtRptTo">Completed To</label>
                <input type="text" id="txtRptTo" class="form-control" placeholder="yyyy-mm-dd">
            </div>

            <div class="col-lg-4 col-md-12">
                <div class="ra-actions-panel">
                    <button id="searchRiskAssessmentBtn" class="btn ra-btn ra-btn-primary">
                        <i class="fa fa-search me-1"></i>Search
                    </button>
                    <button id="downloadRAReport" class="btn ra-btn ra-btn-soft"
                            data-loading-text="Downloading..."
                            data-original-text='<i class="fa fa-download"></i> Download'>
                        <i class="fa fa-download me-1"></i>Download
                    </button>
                    <button id="clearSearchRAReport" class="btn ra-btn ra-btn-soft">
                        <i class="fa fa-refresh me-1"></i>Clear
                    </button>
                </div>
            </div>
        </div>
    </section>

    <section class="ra-table-card">
        <div class="ra-table-head">
            <h2>Risk Assessment Results</h2>
            <span class="ra-table-hint">Use filters to quickly identify incomplete, unsigned, or issue-related assessments.</span>
        </div>

        <div id="divMessageRAResp" class="mb-3"></div>

        <div class="table-responsive" id="div-report-container">
            <table class="table table-hover align-middle" id="riskAssessmentReport" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Email</th>
                        <th>@ELG.Web.Helper.SessionHelper.CompanySettings.strLocationDescription</th>
                        <th>@ELG.Web.Helper.SessionHelper.CompanySettings.strDepartmentDescription</th>
                        <th>Risk Assessment</th>
                        <th>Assigned On</th>
                        <th>Issue Count</th>
                        <th>Signed Off</th>
                        <th>Status</th>
                        <th>Completion Date</th>
                    </tr>
                </thead>
            </table>
        </div>
    </section>
</div>

<div id="individualRAPrintSection"></div>

@Html.Partial("_RiskAssessmentResponse")

<style>
    .ra-modern-page {
        --ra-surface: #ffffff;
        --ra-line: #d9e5ea;
        --ra-text: #12303a;
        --ra-muted: #6a808c;
        --ra-brand: var(--color-primary, #0b7d78);
        --ra-brand-soft: #e9f6f4;
        --ra-shadow: 0 8px 18px rgba(17, 39, 47, 0.06);
        color: var(--ra-text);
    }

    .ra-hero {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        padding: 0.2rem 0.2rem 0.65rem;
        margin-bottom: 0.45rem;
    }

    .ra-breadcrumb {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        margin-bottom: 0.45rem;
        color: var(--ra-muted);
        font-size: 0.88rem;
    }

    .ra-breadcrumb a {
        color: var(--ra-muted);
        text-decoration: none;
    }

    .ra-breadcrumb a:hover {
        color: var(--ra-text);
        text-decoration: underline;
    }

    .ra-title {
        margin: 0;
        font-size: 2.1rem;
        font-weight: 800;
        letter-spacing: 0.2px;
        line-height: 1.15;
    }

    .ra-subtitle {
        margin: 0.3rem 0 0;
        color: #5d6f7a;
        font-size: 1.05rem;
        line-height: 1.35;
    }

    .ra-back-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        border: 1px solid var(--ra-brand);
        color: var(--ra-brand);
        background: #fff;
        border-radius: 10px;
        padding: 0.45rem 0.75rem;
        font-size: 0.85rem;
        font-weight: 700;
        text-decoration: none;
        white-space: nowrap;
    }

    .ra-back-btn:hover {
        background: var(--ra-brand);
        color: #fff;
        text-decoration: none;
    }

    .ra-filter-card,
    .ra-table-card {
        background: var(--ra-surface);
        border: 1px solid var(--ra-line);
        border-radius: 14px;
        box-shadow: var(--ra-shadow);
    }

    .ra-filter-card {
        padding: 1rem 1rem 0.95rem;
        margin-bottom: 0.95rem;
    }

    .ra-label {
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.45px;
        color: #5f7884;
        margin-bottom: 0.38rem;
        line-height: 1.2;
    }

    .ra-input-group .input-group-text {
        border-color: #d2e3e8;
        background: #f4fbfa;
        color: #446573;
    }

    .ra-modern-page .form-control,
    .ra-modern-page .form-select {
        border-radius: 10px;
        border-color: #d2e3e8;
        box-shadow: none;
        min-height: 2.65rem;
    }

    .ra-modern-page .form-control:focus,
    .ra-modern-page .form-select:focus {
        border-color: #99c9c4;
        box-shadow: 0 0 0 0.16rem rgba(11, 125, 120, 0.12);
    }

    .ra-actions-panel {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.5rem;
    }

    .ra-btn {
        min-height: 2.65rem;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 700;
        line-height: 1.2;
    }

    .ra-btn-primary {
        background: var(--ra-brand);
        border-color: var(--ra-brand);
        color: #fff;
    }

    .ra-btn-primary:hover,
    .ra-btn-primary:focus {
        background: var(--ra-brand);
        border-color: var(--ra-brand);
        color: #fff;
        filter: brightness(0.94);
    }

    .ra-btn-soft {
        background: var(--ra-brand-soft);
        border-color: #cde4e2;
        color: #2a545f;
    }

    .ra-btn-soft:hover,
    .ra-btn-soft:focus {
        background: #dff2ef;
        border-color: #bdddd9;
        color: #1d4751;
    }

    .ra-table-card {
        padding: 0.85rem 1rem 1rem;
    }

    .ra-table-head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 0.7rem;
        padding: 0.15rem 0.1rem 0.7rem;
    }

    .ra-table-head h2 {
        margin: 0;
        font-size: 1.1rem;
        font-weight: 800;
        color: #163641;
        line-height: 1.25;
    }

    .ra-table-hint {
        color: #68808c;
        font-size: 0.83rem;
    }

    #riskAssessmentReport thead th {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.45px;
        color: #56717c;
        background: #f7fbfc;
        border-bottom: 1px solid #deebef;
        white-space: nowrap;
    }

    #riskAssessmentReport tbody td {
        font-size: 0.89rem;
        color: #1f3d47;
        vertical-align: middle;
        white-space: nowrap;
    }

    #riskAssessmentReport tbody tr:hover {
        background: #fbfefe;
    }

    @@media (max-width: 991px) {
        .ra-hero {
            flex-direction: column;
            align-items: stretch;
        }

        .ra-back-btn {
            align-self: flex-start;
        }

        .ra-table-head {
            flex-direction: column;
            align-items: flex-start;
        }
    }

    @@media (max-width: 767px) {
        .ra-title {
            font-size: 1.6rem;
        }

        .ra-filter-card,
        .ra-table-card {
            border-radius: 12px;
        }

        .ra-actions-panel {
            grid-template-columns: 1fr;
        }

        .ra-btn {
            width: 100%;
        }
    }
</style>

@section Scripts{
    <script type="text/javascript" src="~/Scripts/Admin/Reports/riskAssessmentReport.js?v=1.7"></script>
}
