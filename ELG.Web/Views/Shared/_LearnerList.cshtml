<div class="modal fade" id="learnerListModal" tabindex="-1" aria-labelledby="learnerListModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content al-modal-content">
            <div class="modal-header al-modal-header">
                <h5 class="modal-title fw-semibold" id="learnerListModalLabel">
                    <i class="fa fa-users-cog me-2"></i>Assign Admin Rights
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body al-modal-body">
                <div class="al-filter-card mb-3">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-6 col-lg-3">
                            <label class="form-label al-label" for="txtAdminLearner">Search</label>
                            <div class="al-control">
                                <span class="al-control-icon"><i class="fa fa-search"></i></span>
                                <input type="text" id="txtAdminLearner" class="form-control" placeholder="Name or email">
                            </div>
                        </div>

                        <div class="col-md-6 col-lg-3">
                            <label class="form-label al-label" for="ddlAdminLocation">@ELG.Web.Helper.SessionHelper.CompanySettings.strLocationDescription</label>
                            <div class="al-control">
                                <span class="al-control-icon"><i class="fa fa-map-marker"></i></span>
                                <select id="ddlAdminLocation" class="form-select ddl-loc">
                                    <option value="0">Select All</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-6 col-lg-3">
                            <label class="form-label al-label" for="ddlAdminDepartment">@ELG.Web.Helper.SessionHelper.CompanySettings.strDepartmentDescription</label>
                            <div class="al-control">
                                <span class="al-control-icon"><i class="fa fa-sitemap"></i></span>
                                <select id="ddlAdminDepartment" class="form-select ddl-dep">
                                    <option value="0">Select All</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-6 col-lg-3">
                            <div class="al-actions">
                                <button id="searchAdminLearner" class="btn al-btn al-btn-primary">
                                    <i class="fa fa-search"></i>Search
                                </button>
                                <button id="clearSearchAdminLearner" class="btn al-btn al-btn-soft">
                                    <i class="fa fa-times"></i>Clear
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="al-table-card">
                    <div id="admin-learner-message" class="mb-3"></div>
                    <div class="table-responsive" id="learnerListForAdmins">
                        <table class="table table-hover align-middle" id="learnerListForAdminRights" width="100%">
                            <thead>
                                <tr>
                                    <th>User</th>
                                    <th>Email</th>
                                    <th>@ELG.Web.Helper.SessionHelper.CompanySettings.strLocationDescription</th>
                                    <th>@ELG.Web.Helper.SessionHelper.CompanySettings.strDepartmentDescription</th>
                                    <th class="text-center">Action</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="modal-footer al-modal-footer">
                <button type="button" class="btn al-btn al-btn-soft" data-bs-dismiss="modal">
                    <i class="fa fa-times"></i>Close
                </button>
            </div>
        </div>
    </div>
</div>

