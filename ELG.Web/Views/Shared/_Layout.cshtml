    <style>
        .admin-modern-view .learner-menu-bar {
            --tenant-primary: var(--color-primary, var(--bs-primary, #ff8a46));
            --menu-text-color: #3f2f2b;
            background: #efedeb;
            border-right: 1px solid #ded9d4;
            box-shadow: 8px 0 30px rgba(42, 28, 24, 0.08);
            padding-top: 12px;
        }

        .admin-modern-view .learner-menu-bar .logo {
            background: transparent;
            border-bottom: 0;
            padding: 10px 16px 14px;
        }

        .admin-modern-view .learner-menu .menu-icon {
            display: none;
        }

        .admin-modern-view .learner-menu .menu-section-title {
            color: #7d6f67;
            font-size: 0.76rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            padding: 14px 16px 6px;
            margin: 10px 10px 2px;
            list-style: none;
        }

        .admin-modern-view .learner-menu .nav-item > a,
        .admin-modern-view .learner-menu .parent-menu-a {
            position: relative;
            color: var(--menu-text-color) !important;
            background: transparent;
            border: 1px solid transparent;
            border-radius: 18px;
            margin: 6px 16px;
            padding: 12px 16px;
            min-height: 46px;
            font-weight: 600;
            font-size: 17px;
            letter-spacing: 0.1px;
            transition: all 0.22s ease;
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .admin-modern-view .learner-menu .nav-item:not(.active) > a:hover,
        .admin-modern-view .learner-menu .parent-menu-a:hover {
            background: var(--tenant-primary);
            color: #ffffff !important;
            border-color: var(--tenant-primary);
            transform: none;
            box-shadow: 0 8px 16px rgba(25, 35, 52, 0.2);
        }

        .admin-modern-view .learner-menu .nav-item.active > a,
        .admin-modern-view .learner-menu .nav-item > a.active {
            background: var(--tenant-primary);
            border-color: var(--tenant-primary);
            color: #ffffff !important;
            box-shadow: 0 8px 16px rgba(25, 35, 52, 0.2);
        }

        .admin-modern-view .learner-menu .nav-item.active > a:hover,
        .admin-modern-view .learner-menu .nav-item > a.active:hover {
            background: var(--tenant-primary);
            border-color: var(--tenant-primary);
            color: #ffffff !important;
        }

        .admin-modern-view .learner-menu .nav-item.active > a span,
        .admin-modern-view .learner-menu .nav-item > a.active span {
            color: #ffffff;
        }

        .admin-modern-view .learner-menu .nav-item > a::before,
        .admin-modern-view .learner-menu .parent-menu-a::before {
            font-family: FontAwesome;
            font-size: 16px;
            width: 18px;
            text-align: center;
            opacity: 0.85;
            font-weight: 400;
            flex: 0 0 18px;
        }

        .admin-modern-view #dashboardLink > a::before { content: "\f00a"; }
        .admin-modern-view #userLink > a::before { content: "\f0c0"; }
        .admin-modern-view #moduleLink > a::before { content: "\f02d"; }
        .admin-modern-view #manageRALink > a::before { content: "\f132"; }
        .admin-modern-view #docLink > a::before { content: "\f15b"; }
        .admin-modern-view #reportLink > a::before { content: "\f1fe"; }
        .admin-modern-view #settingsLink > a::before,
        .admin-modern-view #settingLink > a::before { content: "\f013"; }
        .admin-modern-view #resourcesLink > a::before { content: "\f0b1"; }
        .admin-modern-view #helpLink > a::before { content: "\f059"; }
        .admin-modern-view #learnerDashboardLink > a::before { content: "\f00a"; }
        .admin-modern-view #learnerCoursesLink > a::before { content: "\f19d"; }
        .admin-modern-view #learnerRiskLink > a::before { content: "\f132"; }
        .admin-modern-view #learnerDocsLink > a::before { content: "\f0f6"; }
        .admin-modern-view #learnerSettingsLink > a::before { content: "\f013"; }
        .admin-modern-view #toggleLearnerLink > a::before { content: "\f19d"; }
        .admin-modern-view #logout > a::before { content: "\f08b"; }
        .admin-modern-view #logout > a {
            font-size: 15px !important;
            font-weight: 400 !important;
            margin: 4px 12px !important;
            padding: 8px 12px !important;
            min-height: 40px !important;
        }

        .admin-modern-view .learner-menu .child_menu {
            background: transparent;
            border-radius: 12px;
            margin: 0 16px 8px;
            padding: 2px 0 8px;
            border-left: 2px solid var(--tenant-primary);
        }

        .admin-modern-view .learner-menu .child_menu li a {
            color: var(--menu-text-color) !important;
            background: transparent;
            border: 1px solid transparent;
            font-size: 15px;
            margin: 2px 0 2px 10px;
            padding: 8px 12px;
            border-radius: 8px;
            font-weight: 500;
            display: block;
        }

        .admin-modern-view .learner-menu .child_menu li a:hover {
            color: #ffffff;
            background: var(--tenant-primary);
            border-color: var(--tenant-primary);
        }

        .admin-modern-view .learner-menu .child_menu li a.active,
        .admin-modern-view .learner-menu .child_menu li a.active:hover {
            background: transparent;
            border-color: transparent;
            color: var(--menu-text-color) !important;
            font-weight: 800;
            box-shadow: none;
        }

        .admin-modern-view .line-partition {
            border-color: #ded3cb !important;
            margin-top: 18px !important;
        }

        .admin-modern-view .profile-details span {
            color: #8c7c72;
        }

        .admin-modern-view .profile-details h2 {
            color: #352823;
        }

        .admin-modern-view .profile.parent-menu {
            position: relative;
            padding-right: 42px;
        }

        .admin-modern-view .profile-menu-toggle {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #8c7c72 !important;
            text-decoration: none;
            border: 0;
            background: transparent;
            padding: 4px;
            line-height: 1;
        }

        .admin-modern-view .profile.parent-menu.open .profile-menu-toggle .fa {
            transform: rotate(180deg);
        }

        .admin-modern-view .profile.parent-menu .profile-child-menu {
            position: absolute;
            left: 12px;
            right: 12px;
            bottom: calc(100% + 10px);
            margin: 0;
            padding: 8px;
            list-style: none;
            background: #ffffff;
            border: 1px solid #ded9d4;
            border-radius: 12px;
            box-shadow: 0 12px 30px rgba(42, 28, 24, 0.12);
            z-index: 5;
        }

        .admin-modern-view .profile.parent-menu .profile-child-menu li {
            margin: 0;
        }

        .admin-modern-view .profile.parent-menu .profile-child-menu li a {
            display: block;
            color: var(--menu-text-color) !important;
            text-decoration: none;
            padding: 8px 10px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
        }

        .admin-modern-view .profile.parent-menu .profile-child-menu li a:hover,
        .admin-modern-view .profile.parent-menu .profile-child-menu li a.active {
            background: var(--tenant-primary);
            color: #ffffff !important;
        }

        .admin-modern-view .admin-viewmode-item {
            margin-left: 0;
            margin-right: 0;
            padding: 6px 0 4px;
        }

        .admin-modern-view .admin-viewmode-label {
            color: #4f3e38;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            font-size: 0.78rem;
        }

        .admin-modern-view .admin-viewmode-caption {
            color: #89786f;
            font-size: 0.72rem;
        }

        .admin-modern-view .admin-viewmode-item .admin-viewmode-row,
        .admin-modern-view .admin-viewmode-item .admin-viewmode-caption {
            margin-left: 12px;
            margin-right: 8px;
        }

        .admin-modern-view .learner-main-content {
            background: radial-gradient(circle at 0% 0%, #fff8f3 0%, #f8fbfd 36%, #ffffff 100%);
        }
    </style>
</head>

