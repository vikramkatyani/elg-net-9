                        {
                            <li class="nav-item parent-menu" id="settingLink">
                                <a class="parent-menu-a">
                                    <i class="fa fa-comments"></i> Communication <span class="fa fa-chevron-down"></span>
                                </a>
                                <ul class="nav child_menu">
