                                    @if (learnerMenuSettings == null || learnerMenuSettings.trainingCard == true)
                                    {
                                        <li><a class="collapse-item" id="menu-trainingcard-report" href="@Url.Action("TrainingCard", "Report", new { area = "" })">Learner Account Snapshot</a></li>
                                    }
                                    @if (learnerMenuSettings != null && learnerMenuSettings.enableWidget == true)
                                    {
                                        <li><a class="collapse-item" id="menu-widget-report" href="@Url.Action("WidgetProgress", "Report", new { area = "" })">Widgets</a></li>
                                    }
                                    @if (learnerMenuSettings != null && learnerMenuSettings.archiveReport == true)
                                    {
                                        <li><a class="collapse-item" id="menu-widget-report" href="@Url.Action("ArchiveReport", "Report", new { area = "" })">Archive Report</a></li>
                                    }
                                </ul>
                            </li>
                        }
                    }
