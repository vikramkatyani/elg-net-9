                                    <li><a class="collapse-item" href="@Url.Action("ModuleReminder", "Home", new { area = "" })" id="menu-set-reminder">Refreshers</a></li>
                                    <li><a class="collapse-item" href="@Url.Action("Announcements", "Announcement", new { area = "" })" id="menu-announcement">Announcements</a></li>
