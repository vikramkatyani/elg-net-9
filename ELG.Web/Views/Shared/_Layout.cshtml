                                </ul>
                            </li>
                        }*@



                    @if (!isModernViewMode)
                    {
                        <li class="nav-item parent-menu" id="settingsLink">
                            <a class="parent-menu-a">
                                @*<i class="fa fa-cog"></i>*@
                                <img class="menu-icon" src="~/Content/images/icons/settings.png" alt="Settings" /> Settings <span class="fa fa-chevron-down"></span>
                            </a>
                            <ul class="nav child_menu">
                                <li><a class="user-profile-btn" id="menu-user-profile" data-id="btnUserProfile-@ELG.Web.Helper.SessionHelper.UserId" href="@Url.Action("MyProfile", "Home", new { area = "" })"> Profile</a></li>
                                <li><a id="menu-user-password" href="@Url.Action("ChangePassword", "Home", new { area = "" })"> Update password </a></li>
                            </ul>
                        </li>
                    }

                    @if (isModernViewMode && ELG.Web.Helper.SessionHelper.HasLearnerRights)
                    {
                        <li class="menu-section-title">Learner</li>

                        @if (learnerSectionMenuSettings == null || learnerSectionMenuSettings.dashboard == true)
                        {
                            <li class="nav-item @(isLearnerDashboardPage ? "active" : string.Empty)" id="learnerDashboardLink">
                                <a id="menu-learner-dashboard" href="@Url.Action("Dashboard", "Home", new { area = "Learner" })">Dashboard</a>
                            </li>
                        }

                        <li class="nav-item @(isLearnerMyCoursesPage ? "active" : string.Empty)" id="learnerCoursesLink">
                            <a id="menu-learner-courses" href="@Url.Action("MyCourses", "Home", new { area = "Learner" })">My Courses</a>
                        </li>

                        @if (learnerSectionMenuSettings == null || learnerSectionMenuSettings.ra == true)
                        {
                            <li class="nav-item @(isLearnerRiskPage ? "active" : string.Empty)" id="learnerRiskLink">
                                <a id="menu-learner-ra" href="@Url.Action("Assessment", "RiskAssessment", new { area = "Learner" })">Risk Assessments</a>
                            </li>
                        }

                        @if (learnerSectionMenuSettings == null || learnerSectionMenuSettings.doc == true)
                        {
                            <li class="nav-item @(isLearnerDocumentsPage ? "active" : string.Empty)" id="learnerDocsLink">
                                <a id="menu-learner-docs" href="@Url.Action("List", "Document", new { area = "Learner" })">Documents</a>
