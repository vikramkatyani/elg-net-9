<div class="modal fade" id="addSubCategoryModal" tabindex="-1" aria-labelledby="addSubCategoryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-sm doc-modal-content">
            <div class="modal-header doc-modal-header">
                <h5 class="modal-title fw-bold doc-modal-title" id="addSubCategoryModalLabel">Add Sub Category</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body doc-modal-body">
                <!-- Alert Message -->
                <div class="alert alert-danger d-none" role="alert" id="addSubCategoryMessage"></div>

                <!-- Form -->
                <form id="addSubCategoryForm" class="needs-validation" novalidate>
                    <div class="form-floating mb-3 w-100">
                        <textarea id="txtSubCategoryName" class="form-control" placeholder="Sub Category Name" style="height: 80px" required></textarea>
                        <label for="txtSubCategoryName">Sub Category</label>
                    </div>

                    <div class="form-floating mb-3 w-100">
                        <textarea id="txtSubCategoryDesc" class="form-control" placeholder="Description" style="height: 100px"></textarea>
                        <label for="txtSubCategoryDesc">Description</label>
                    </div>
                </form>
            </div>

            <div class="modal-footer doc-modal-footer">
                <button type="button" class="btn doc-modal-btn doc-modal-btn-soft" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn doc-modal-btn doc-modal-btn-primary" id="btnAddNewSubCategory" data-loading-text="Creating..." data-original-text="Add">Add</button>
            </div>
        </div>
    </div>
</div>


