
@{
    ViewBag.Title = "Document Category";
    //check admin privileges
    var adminRole = ELG.Web.Helper.SessionHelper.UserRole;
    if (adminRole > 0)
    {
        Layout = ELG.Web.Helper.CommonHelper.GetAdminLayoutPage(adminRole);
    }
    else
    {
        <div class="alert alert-danger">Unauthorized access. Please <a href="@Url.Action("LogOut", "Account")">log out</a>.</div>
    }
}
@model List<ELG.Model.OrgAdmin.LearnerInfo>

<div class="x_panel tile">
    <div class="x_title">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h3 text-primary fw-bold mb-0">Manage Document Categories</h1>
            @{ if (adminRole == 1)
                {
                    <button id="btnShowCategoryPopUp" class="btn btn-success">
                        <i class="fa fa-plus-circle me-1"></i> Add Category
                    </button>
                }
            }
        </div>

        <!-- Filter & Action Section -->
        <div class="card mb-4">
            <div class="card-body">
                <div class="row g-3 align-items-end">

                    <!-- Category Search -->
                    <div class="col-md-6 col-lg-4">
                        <div class="form-floating">
                            <input type="text" id="txtDocCategory" class="form-control" placeholder="Category name">
                            <label for="txtDocCategory">Category</label>
                        </div>
                    </div>

                    <!-- Search & Clear Buttons -->
                    <div class="col-md-6 col-lg-4 d-flex gap-2 justify-content-end">
                        <button id="searchDocCategory" class="btn btn-primary">
                            <i class="fa fa-search me-1"></i> Search
                        </button>
                        <button id="clearSearchDocCategory" class="btn btn-secondary">
                            <i class="fa fa-times me-1"></i> Clear
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Table Section -->
    <div class="x_content">
        <div id="messageCategory"></div>

        <div class="table-responsive">
            <table class="table table-striped table-hover table-bordered align-middle" id="docCategoryList" width="100%" cellspacing="0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Created On</th>
                        <th class="text-center" style="width: 5%;">Action</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>
@Html.Partial("_addCategory")
@Html.Partial("_addSubCategory")

<style>
    #docCategoryList .dc-row-actions-trigger {
        width: 2rem;
        height: 2rem;
        border: 1px solid #d2e2e8;
        border-radius: 8px;
        background: #f7fbfd;
        color: #2f5662;
    }

    #docCategoryList .dc-row-actions-trigger:hover,
    #docCategoryList .dc-row-actions.show .dc-row-actions-trigger {
        background: #eef7fb;
        border-color: #bfd7dd;
        color: #204652;
    }

    #docCategoryList .dc-row-actions-menu {
        min-width: 220px;
        border: 1px solid #d7e6ea;
        border-radius: 10px;
        box-shadow: 0 10px 20px rgba(16, 40, 46, 0.12);
        padding: 0.35rem;
    }

    #docCategoryList .dc-row-actions-item {
        border-radius: 8px;
        font-size: 0.84rem;
        font-weight: 600;
        color: #2c4f5a;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.42rem 0.52rem;
    }

    #docCategoryList .dc-row-actions-item-icon {
        width: 16px;
        text-align: center;
        color: #2e6f7c;
    }

    #docCategoryList .dc-row-actions-item:hover,
    #docCategoryList .dc-row-actions-item:focus {
        background: #eef7fb;
        color: #1f4652;
    }

    #docCategoryList .dc-sub-actions {
        margin-top: 0.45rem;
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
    }

    #docCategoryList .dc-sub-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
        background: #f8fcfd;
        border: 1px solid #dfecf0;
        border-radius: 8px;
        padding: 0.25rem 0.4rem;
    }

    #docCategoryList .dc-sub-item-name {
        font-size: 0.9rem;
        color: #345965;
        line-height: 1.2;
    }

    #docCategoryList .dc-sub-item-actions {
        display: inline-flex;
        gap: 0.3rem;
        flex: 0 0 auto;
    }

    #docCategoryList .dc-sub-action-btn {
        width: 1.9rem;
        height: 1.9rem;
        border: 1px solid #d2e2e8;
        border-radius: 7px;
        background: #f7fbfd;
        color: #2f5662;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0;
    }

    #docCategoryList .dc-sub-action-btn:hover {
        background: #eef7fb;
        border-color: #bfd7dd;
        color: #204652;
    }
</style>


@section Scripts{
    <script type="text/javascript" src="~/Scripts/Admin/Document/manageCategory.js"></script>
    <script type="text/javascript" src="~/Scripts/Admin/Document/manageSubCategory.js"></script>
}
