@{
    ViewBag.Title = "Insights & Reports";

    var adminRole = ELG.Web.Helper.SessionHelper.UserRole;
    Layout = ELG.Web.Helper.CommonHelper.GetAdminLayoutPage(adminRole);

    var learnerMenuSettingsJson = ELG.Web.Helper.SessionHelper.OrgAdminAvailableMenu as string;
    dynamic learnerMenuSettings = !string.IsNullOrEmpty(learnerMenuSettingsJson)
        ? Newtonsoft.Json.JsonConvert.DeserializeObject(learnerMenuSettingsJson)
        : null;

    bool canSummary = learnerMenuSettings == null || learnerMenuSettings.summaryReport == true;
    bool canLearning = learnerMenuSettings == null || learnerMenuSettings.learningReport == true;
    bool canRA = learnerMenuSettings == null || learnerMenuSettings.raReport == true;
    bool canDocument = learnerMenuSettings == null || learnerMenuSettings.documentReport == true;
    bool canTrainingCard = learnerMenuSettings == null || learnerMenuSettings.trainingCard == true;
    bool canWidget = learnerMenuSettings != null && learnerMenuSettings.enableWidget == true;
    bool canArchive = learnerMenuSettings != null && learnerMenuSettings.archiveReport == true;
}

<div class="ir-page">
    <header class="ir-hero">
        <h1>Reports & Analytics</h1>
        <p>Generate comprehensive reports and insights about your LMS.</p>
    </header>

    <div class="ir-filters" role="tablist" aria-label="Report categories">
        <button type="button" class="ir-filter is-active" data-filter="all">All Reports</button>
        <button type="button" class="ir-filter" data-filter="users">Users & Engagement</button>
        <button type="button" class="ir-filter" data-filter="courses">Course Analytics</button>
        <button type="button" class="ir-filter" data-filter="pathways">Learning Pathways</button>
        <button type="button" class="ir-filter" data-filter="administrative">Administrative</button>
    </div>

    <section class="ir-grid" id="reportsGrid">
        @if (canSummary)
        {
            <a class="ir-card" href="@Url.Action("Summary", "Report")" data-cat="users courses">
                <span class="ir-icon bg-mint"><i class="fa fa-clock-o" aria-hidden="true"></i></span>
                <h3>Overview Report</h3>
                <p>Track completion, activity trends, and key adoption metrics in one snapshot.</p>
            </a>
        }

        @if (canLearning)
        {
            <a class="ir-card" href="@Url.Action("LearningProgress", "Report")" data-cat="users courses pathways">
                <span class="ir-icon bg-navy"><i class="fa fa-line-chart" aria-hidden="true"></i></span>
                <h3>User Progress Report</h3>
                <p>View individual learner progress across assigned courses and learning pathways.</p>
            </a>

            <a class="ir-card" href="@Url.Action("SubModuleProgress", "Report")" data-cat="courses pathways">
                <span class="ir-icon bg-indigo"><i class="fa fa-sitemap" aria-hidden="true"></i></span>
                <h3>Sub-module Progress</h3>
                <p>Inspect granular progress inside modules, sections, and sub-module checkpoints.</p>
            </a>

            <a class="ir-card" href="@Url.Action("HistoricRecords", "Report")" data-cat="users courses">
                <span class="ir-icon bg-rose"><i class="fa fa-history" aria-hidden="true"></i></span>
                <h3>Historic Records</h3>
                <p>Review completion history and archived learner records over time.</p>
            </a>
        }

        @if (canRA)
        {
            <a class="ir-card" href="@Url.Action("RiskAssessmentReport", "Report")" data-cat="administrative courses">
                <span class="ir-icon bg-violet"><i class="fa fa-exclamation-triangle" aria-hidden="true"></i></span>
                <h3>Risk Assessment Report</h3>
                <p>Monitor risk assessment progress, sign-off status, and unresolved issues.</p>
            </a>
        }

        @if (canDocument)
        {
            <a class="ir-card" href="@Url.Action("DocumentReport", "Report")" data-cat="administrative users">
                <span class="ir-icon bg-cyan"><i class="fa fa-file-text-o" aria-hidden="true"></i></span>
                <h3>Document Report</h3>
                <p>Analyse document assignment, acknowledgement, and completion activity.</p>
            </a>
        }

        @if (canTrainingCard)
        {
            <a class="ir-card" href="@Url.Action("TrainingCard", "Report")" data-cat="users pathways">
                <span class="ir-icon bg-gold"><i class="fa fa-id-card-o" aria-hidden="true"></i></span>
                <h3>Learner Account Snapshot</h3>
                <p>Open training card level details by learner with account and completion context.</p>
            </a>
        }

        @if (canWidget)
        {
            <a class="ir-card" href="@Url.Action("WidgetProgress", "Report")" data-cat="courses administrative">
                <span class="ir-icon bg-slate"><i class="fa fa-cubes" aria-hidden="true"></i></span>
                <h3>Widget Progress</h3>
                <p>Evaluate widget completion and learning interactions across users and groups.</p>
            </a>
        }

        @if (canArchive)
        {
            <a class="ir-card" href="@Url.Action("ArchiveReport", "Report")" data-cat="administrative users">
                <span class="ir-icon bg-teal"><i class="fa fa-archive" aria-hidden="true"></i></span>
                <h3>Archive Report</h3>
                <p>Review archived learning data and retained records for audit and compliance.</p>
            </a>
        }
    </section>
</div>

<style>
    .ir-page {
        max-width: 1240px;
        margin: 0 auto;
        padding: 24px 8px 30px;
    }

    .ir-hero h1 {
        margin: 0;
        font-size: 2rem;
        font-weight: 700;
        color: #12243a;
    }

    .ir-hero p {
        margin: 8px 0 0;
        color: #57687c;
        font-size: 0.98rem;
    }

    .ir-filters {
        margin-top: 18px;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
        border-radius: 10px;
        padding: 8px;
    }

    .ir-filter {
        border: 1px solid transparent;
        background: transparent;
        color: #5c6c80;
        font-weight: 600;
        padding: 7px 12px;
        border-radius: 8px;
        font-size: 0.88rem;
        cursor: pointer;
        transition: all .2s ease;
    }

    .ir-filter:hover {
        background: #eef4ff;
        color: #1f3d66;
    }

    .ir-filter.is-active {
        background: #eaf2ff;
        color: #163a6b;
        border-color: #c8daf8;
    }

    .ir-grid {
        margin-top: 16px;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
    }

    .ir-card {
        position: relative;
        display: block;
        text-decoration: none;
        border: 1px solid #dde5ef;
        border-radius: 12px;
        padding: 14px;
        min-height: 172px;
        background: #ffffff;
        transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
    }

    .ir-card:hover {
        transform: translateY(-2px);
        border-color: #b8c9df;
        box-shadow: 0 10px 24px rgba(14, 38, 68, 0.09);
    }

    .ir-card h3 {
        margin: 12px 0 8px;
        color: #102236;
        font-size: 1.05rem;
        font-weight: 700;
    }

    .ir-card p {
        margin: 0;
        color: #56677b;
        font-size: 0.9rem;
        line-height: 1.45;
    }

    .ir-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #fff;
    }

    .bg-mint { background: #29d39a; }
    .bg-navy { background: #254271; }
    .bg-rose { background: #ff3967; }
    .bg-violet { background: #7e2ce2; }
    .bg-cyan { background: #0ea5b7; }
    .bg-gold { background: #efad00; }
    .bg-indigo { background: #4f46e5; }
    .bg-slate { background: #334155; }
    .bg-teal { background: #0f766e; }

    .ir-card.is-hidden {
        display: none;
    }

    @@media (max-width: 1100px) {
        .ir-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 700px) {
        .ir-page {
            padding: 16px 0 24px;
        }

        .ir-grid {
            grid-template-columns: 1fr;
        }

        .ir-hero h1 {
            font-size: 1.6rem;
        }
    }
</style>

<script>
    (function () {
        var filterButtons = document.querySelectorAll('.ir-filter');
        var cards = document.querySelectorAll('.ir-card');

        function applyFilter(filter) {
            cards.forEach(function (card) {
                if (filter === 'all') {
                    card.classList.remove('is-hidden');
                    return;
                }

                var categories = (card.getAttribute('data-cat') || '').split(' ');
                var match = categories.indexOf(filter) !== -1;
                card.classList.toggle('is-hidden', !match);
            });
        }

        filterButtons.forEach(function (btn) {
            btn.addEventListener('click', function () {
                filterButtons.forEach(function (b) { b.classList.remove('is-active'); });
                btn.classList.add('is-active');
                applyFilter(btn.getAttribute('data-filter'));
            });
        });
    })();
</script>
