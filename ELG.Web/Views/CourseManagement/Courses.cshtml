@{
    ViewBag.Title = "Configure Course";
    //check admin privileges
    var adminRole = ELG.Web.Helper.SessionHelper.UserRole;
    Layout = ELG.Web.Helper.CommonHelper.GetAdminLayoutPage(adminRole);
}

<div class="x_panel tile">
    <div class="x_title mb-3">
        <h1 class="h3 text-primary fw-bold">Course Setup</h1>
    </div>

    <section class="cm-stats-grid" aria-label="Course summary stats">
        <article class="cm-stat-pill is-selected" data-course-filter="0" role="button" tabindex="0" aria-label="Show all courses">
            <div class="cm-stat-icon"><i class="fa fa-book"></i></div>
            <div>
                <div class="cm-stat-label">Total Courses</div>
                <div class="cm-stat-value" id="pillTotalCourses">-</div>
            </div>
        </article>
        <article class="cm-stat-pill" data-course-filter="1" role="button" tabindex="0" aria-label="Show courses with no assignments">
            <div class="cm-stat-icon is-muted"><i class="fa fa-ban"></i></div>
            <div>
                <div class="cm-stat-label">No Assignments</div>
                <div class="cm-stat-value" id="pillNoAssignmentCourses">-</div>
            </div>
        </article>
        <article class="cm-stat-pill" data-course-filter="2" role="button" tabindex="0" aria-label="Show courses with submodules">
            <div class="cm-stat-icon is-active"><i class="fa fa-sitemap"></i></div>
            <div>
                <div class="cm-stat-label">With Submodules</div>
                <div class="cm-stat-value" id="pillWithSubmoduleCourses">-</div>
            </div>
        </article>
    </section>

    <div class="card mb-4">
        <div class="card-body">
            <!-- Row 1: Filters -->
            <div class="row g-3 align-items-end">
                <div class="col-lg-4 col-md-6 col-sm-12">
                    <div class="form-floating">
                        <input type="text" class="form-control" id="txtModule" placeholder="Course Name">
                        <label for="txtModule">Course Name</label>
                    </div>
                </div>

                <div class="col-lg-2 col-md-4 col-sm-6">
                    <button id="searchModuleBtn" class="btn btn-primary w-100">
                        <i class="fa fa-search me-1"></i> Search
                    </button>
                </div>

                <div class="col-lg-2 col-md-4 col-sm-6">
                    <button id="clearSearchModuleBtn" class="btn btn-secondary w-100">
                        <i class="fa fa-times me-1"></i> Clear
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Table Section -->
    <div class="x_content">
        <div id="message_course_setup"></div>
        <div class="cm-view-toggle mb-3">
            <button id="courseViewListBtn" type="button" class="btn btn-primary btn-sm active">
                <i class="fa fa-list"></i> List View
            </button>
            <button id="courseViewGridBtn" type="button" class="btn btn-outline-primary btn-sm ms-2">
                <i class="fa fa-th-large"></i> Grid View
            </button>
        </div>
        <div class="table-responsive" id="course-setup-container">
            <table class="table table-striped table-hover table-bordered align-middle" id="configureModuleList" width="100%" cellspacing="0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 80px;"></th>
                        <th>Course</th>
                        <th>Sub-Module</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Dynamic rows go here -->
                </tbody>
            </table>
        </div>
        <div id="courseGridContainer" class="row g-3 d-none"></div>
    </div>
</div>
 @Html.Partial("_addSubModule")
 @Html.Partial("_courseSubModule" )
 @Html.Partial("_mapRiskAssessment")
 @Html.Partial("_createRiskAssessment")
 @Html.Partial("_editCourse")

<style>
    .cm-stats-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .cm-stat-pill {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        border: 1px solid #d9e6ea;
        border-radius: 12px;
        background: #ffffff;
        padding: 0.78rem 0.85rem;
        cursor: pointer;
        transition: all 0.18s ease;
    }

    .cm-stat-pill:hover {
        border-color: #8bc8c3;
        box-shadow: 0 10px 20px rgba(12, 71, 80, 0.1);
        transform: translateY(-1px);
    }

    .cm-stat-pill.is-selected {
        border-color: #0b7d78;
        background: #eaf7f5;
    }

    .cm-stat-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #e6f3f4;
        color: #0b7d78;
    }

    .cm-stat-icon.is-active {
        background: #e3f5ef;
        color: #187f59;
    }

    .cm-stat-icon.is-muted {
        background: #f3f5f7;
        color: #6b7f89;
    }

    .cm-stat-label {
        font-size: 0.76rem;
        color: #60757f;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .cm-stat-value {
        font-size: 1.35rem;
        line-height: 1.1;
        font-weight: 800;
        color: #173943;
    }

    .cm-card {
        border: 1px solid #d9e5ea;
        border-radius: 12px;
        background: #fff;
        padding: 0;
        overflow: hidden;
        height: 100%;
        box-shadow: 0 4px 12px rgba(17, 42, 48, 0.06);
    }

    .cm-card-head {
        width: 100%;
        height: 182px;
        overflow: hidden;
        border-bottom: 1px solid #d9e5ea;
        background: #f3f8fb;
    }

    .cm-card-thumb {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 0;
        border: 0;
        background: #f7fbfd;
    }

    .cm-card-body {
        padding: 0.85rem;
    }

    .cm-card-title {
        margin: 0 0 0.7rem;
        font-weight: 700;
        color: #1d3c47;
        min-height: 44px;
    }

    .cm-card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.5rem;
    }

    .cm-card-submodule-group {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
    }

    .cm-card-actions .cm-row-actions {
        margin: 0;
    }

    .cm-card-actions .cm-row-actions-trigger-card {
        width: 2rem;
        height: 2rem;
        border-radius: 8px;
        border: 0 !important;
        background: transparent !important;
        color: #2f5662;
        box-shadow: none !important;
    }

    .cm-card-actions .cm-row-actions-trigger-card:hover {
        border: 0 !important;
        background: transparent !important;
        color: #204652;
        box-shadow: none !important;
    }

    .cm-card-actions .cm-row-actions.show .cm-row-actions-trigger-card,
    .cm-card-actions .cm-row-actions-trigger-card:focus,
    .cm-card-actions .cm-row-actions-trigger-card:focus-visible {
        border: 0 !important;
        background: transparent !important;
        box-shadow: none !important;
    }

    .cm-card-submodule {
        font-size: 0.82rem;
        color: #4c6a75;
    }

    @@media (max-width: 991px) {
        .cm-stats-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
@section Scripts{
    <script type="text/javascript" src="~/Scripts/Admin/CourseManagement/ManageModule.js"></script>
}

