@{
    ViewBag.Title = "Document Group";
    //check admin privileges
    var adminRole = ELG.Web.Helper.SessionHelper.UserRole;
    if (adminRole > 0)
    {
        Layout = ELG.Web.Helper.CommonHelper.GetAdminLayoutPage(adminRole);
    }
    else
    {
        <div class="alert alert-danger">Unauthorized access. Please <a href="@Url.Action("LogOut", "Account")">log out</a>.</div>
    }
}

<div class="dg-modern-page" id="documentBundlePage">
    <section class="dg-hero">
        <div>
            <h1 class="dg-title">Manage Document Groups</h1>
            <p class="dg-subtitle">Create bundles, map documents, and assign groups to users from one streamlined screen.</p>
        </div>

        <button id="btnShowDocGroupPopUp" class="btn dg-btn dg-btn-success">
            <i class="fa fa-plus-circle"></i>Add Group
        </button>
    </section>

    <section class="dg-filter-card">
        <div class="dg-filter-head">
            <h2>Filters</h2>
            <p>Search by document group name.</p>
        </div>

        <div class="row g-3 align-items-end">
            <div class="col-lg-8 col-md-7 col-sm-12">
                <label class="form-label dg-label" for="txtDoc">Group Name</label>
                <div class="dg-control">
                    <span class="dg-control-icon"><i class="fa fa-folder-open-o"></i></span>
                    <input type="text" id="txtDoc" class="form-control" placeholder="Search group name">
                </div>
            </div>

            <div class="col-lg-4 col-md-5 col-sm-12">
                <div class="dg-actions">
                    <button id="searchDoc" class="btn dg-btn dg-btn-primary">
                        <i class="fa fa-search"></i>Search
                    </button>
                    <button id="clearSearchDoc" class="btn dg-btn dg-btn-soft">
                        <i class="fa fa-times"></i>Clear
                    </button>
                </div>
            </div>
        </div>
    </section>

    <section class="dg-table-card">
        <div class="dg-table-head">
            <h2>Document Groups</h2>
            <span class="dg-table-hint">Use the action menu to edit, delete, map documents, or assign a group to users.</span>
        </div>

        <div id="messageDocumentGroup" class="mb-3"></div>

        <div class="table-responsive" id="div-report-container">
            <table class="table table-hover align-middle" id="orgDocumentGroupList" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>@ELG.Web.Helper.SessionHelper.CompanySettings.strLocationDescription</th>
                        <th>Documents</th>
                        <th style="width: 5%;">Action</th>
                    </tr>
                </thead>
            </table>
        </div>
    </section>
</div>

@Html.Partial("_addDocumentGroup")

<style>
    .dg-modern-page {
        --dg-surface: #ffffff;
        --dg-line: #d9e6ea;
        --dg-text: #14323c;
        --dg-muted: #627f8a;
        --dg-brand: var(--color-primary, #0b7d78);
        --dg-brand-alt: var(--color-secondary, #0f968f);
        --dg-brand-soft: #e8f5f3;
        --dg-shadow: 0 14px 30px rgba(17, 42, 48, 0.08);
        color: var(--dg-text);
        direction: ltr;
    }

    .dg-modern-page *,
    .dg-modern-page *::before,
    .dg-modern-page *::after {
        box-sizing: border-box;
    }

    .dg-hero {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 1rem;
        background: linear-gradient(145deg, #effaf8, #edf6fb);
        border: 1px solid #d8e9ec;
        border-radius: 13px;
        padding: 1rem 1.15rem;
        margin-bottom: 1rem;
    }

    .dg-title {
        margin: 0;
        font-size: 1.5rem;
        font-weight: 800;
        letter-spacing: 0.2px;
    }

    .dg-subtitle {
        margin: 0.28rem 0 0;
        font-size: 0.92rem;
        line-height: 1.45;
        color: var(--dg-muted);
    }

    .dg-filter-card,
    .dg-table-card {
        background: var(--dg-surface);
        border: 1px solid var(--dg-line);
        border-radius: 14px;
        box-shadow: var(--dg-shadow);
    }

    .dg-filter-card {
        padding: 1rem;
        margin-bottom: 1rem;
    }

    .dg-filter-head {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        flex-wrap: wrap;
        gap: 0.8rem;
        margin-bottom: 0.8rem;
    }

    .dg-filter-head h2 {
        margin: 0;
        font-size: 1.02rem;
        font-weight: 700;
    }

    .dg-filter-head p {
        margin: 0;
        font-size: 0.8rem;
        color: var(--dg-muted);
    }

    .dg-label {
        font-size: 0.76rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: #56707b;
        margin-bottom: 0.3rem;
    }

    .dg-control {
        display: flex;
        align-items: stretch;
        width: 100%;
        min-width: 0;
        border: 1px solid #cfe0e4;
        border-radius: 10px;
        background: #fff;
        overflow: hidden;
    }

    .dg-control:hover {
        border-color: #bad6dc;
    }

    .dg-control:focus-within {
        border-color: #90c8c4;
        box-shadow: 0 0 0 0.2rem rgba(11, 125, 120, 0.14);
    }

    .dg-control-icon {
        width: 46px;
        min-width: 46px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: var(--dg-brand-soft);
        color: var(--dg-brand);
        border-right: 1px solid #cde2de;
    }

    .dg-control .form-control {
        border: 0;
        border-radius: 0;
        width: 100%;
        min-width: 0;
        height: 44px;
        box-shadow: none;
    }

    .dg-actions {
        display: flex;
        justify-content: flex-end;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .dg-btn {
        min-width: 114px;
        height: 40px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.34rem;
        font-size: 0.84rem;
        font-weight: 700;
        border: 1px solid transparent;
        transition: transform 0.15s ease, box-shadow 0.15s ease;
    }

    .dg-btn:hover {
        transform: translateY(-1px);
    }

    .dg-btn:focus-visible {
        outline: none;
        box-shadow: 0 0 0 3px rgba(11, 125, 120, 0.24);
    }

    .dg-btn-primary {
        color: #fff;
        background: var(--dg-brand);
        box-shadow: 0 8px 16px rgba(11, 125, 120, 0.2);
    }

    .dg-btn-primary:hover,
    .dg-btn-primary:focus {
        color: #fff;
    }

    .dg-btn-soft {
        color: #2e515d;
        background: #f7fbfd;
        border-color: #d2e2e8;
    }

    .dg-btn-success {
        color: #fff;
        background: #1a8f58;
        box-shadow: 0 8px 16px rgba(26, 143, 88, 0.2);
    }

    .dg-table-card {
        padding: 1rem;
    }

    .dg-table-head {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        flex-wrap: wrap;
        gap: 0.8rem;
        margin-bottom: 0.65rem;
    }

    .dg-table-head h2 {
        margin: 0;
        font-size: 1.05rem;
        font-weight: 700;
    }

    .dg-table-hint {
        color: var(--dg-muted);
        font-size: 0.8rem;
    }

    .dg-modern-page table.dataTable thead th {
        background: #f4faf9;
        border-bottom: 1px solid #dce9eb;
        color: #32515c;
        font-size: 0.82rem;
        vertical-align: middle;
    }

    .dg-modern-page .table-hover tbody tr:hover {
        background: #f5fbff;
    }

    .dg-modern-page table.dataTable tbody td {
        padding-top: 0.72rem;
        padding-bottom: 0.72rem;
        border-color: #e1ecef;
        vertical-align: middle;
    }

    .dg-modern-page .dg-row-actions-trigger {
        width: 2.45rem;
        height: 2.45rem;
        border: 1px solid #d2e2e8;
        background: #f7fbfd;
        color: #2f5662;
        transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
    }

    .dg-modern-page .dg-row-actions-trigger:hover {
        transform: translateY(-1px);
        background: #eef7fb;
        color: #204652;
    }

    .dg-modern-page .dg-row-actions-trigger:focus-visible,
    .dg-modern-page .dg-row-actions.show .dg-row-actions-trigger {
        outline: none;
        border-color: #8fc8c4;
        box-shadow: 0 0 0 0.2rem rgba(11, 125, 120, 0.14);
        color: var(--dg-brand);
    }

    .dg-modern-page .dg-row-actions-menu {
        min-width: 220px;
        border: 1px solid #d7e6ea;
        border-radius: 12px;
        box-shadow: 0 14px 28px rgba(16, 40, 46, 0.14);
        padding: 0.35rem;
    }

    .dg-modern-page .dg-row-actions-item {
        border-radius: 8px;
        font-size: 0.84rem;
        font-weight: 600;
        color: #2c4f5a;
        display: flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0.45rem 0.55rem;
    }

    .dg-modern-page .dg-row-actions-item-icon {
        width: 18px;
        text-align: center;
        color: #2e6f7c;
        opacity: 0.95;
    }

    .dg-modern-page .dg-row-actions-item:hover,
    .dg-modern-page .dg-row-actions-item:focus {
        background: #eef7fb;
        color: #1f4652;
    }
</style>

@section Scripts{
    <script type="text/javascript" src="~/Scripts/Admin/Document/manageDocumentGroup.js?v=1.0.3"></script>
}
