@model ELG.Web.Models.ChangePasswordViewModel
@{
    ViewBag.Title = "Change Password";
    Layout = ELG.Web.Helper.SessionHelper.IsLearnerUser
        ? "~/Areas/Learner/Views/Shared/_Layout.cshtml"
        : "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="cp-modern-page" id="changePasswordPage">
        <section class="cp-hero">
            <div>
                <h1 class="cp-title">Update Password</h1>
                <p class="cp-subtitle">Use a strong password to keep your account secure and protected.</p>
            </div>
        </section>

        <section class="cp-content-card">
            <div class="row justify-content-start">
                <div class="col-xl-6 col-lg-7 col-md-9 col-sm-12">
                    @if (!string.IsNullOrEmpty(ViewBag.Message as string))
                    {
                        <div class="alert alert-success" id="tempSuccessMsg">@ViewBag.Message</div>
                    }

                    @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

                    @using (Html.BeginForm("ChangePassword", "Home", FormMethod.Post, new { @class = "needs-validation", id = "frmChangePassword", name = "frmChangePassword", novalidate = "novalidate" }))
                    {
                        <div class="mb-3 w-100">
                            <label class="form-label cp-label" for="OldPassword">Old Password</label>
                            <div class="cp-control">
                                <span class="cp-control-icon"><i class="fa fa-lock"></i></span>
                                @Html.PasswordFor(m => m.OldPassword, new { @class = "form-control", placeholder = "Enter old password", required = "required" })
                            </div>
                            @Html.ValidationMessageFor(model => model.OldPassword, "", new { @class = "text-danger small" })
                        </div>

                        <div class="mb-3 w-100">
                            <label class="form-label cp-label" for="NewPassword">New Password</label>
                            <div class="cp-control">
                                <span class="cp-control-icon"><i class="fa fa-key"></i></span>
                                @Html.PasswordFor(m => m.NewPassword, new { @class = "form-control", placeholder = "Enter new password", required = "required" })
                            </div>
                            @Html.ValidationMessageFor(model => model.NewPassword, "", new { @class = "text-danger small" })
                        </div>

                        <div class="mb-4 w-100">
                            <label class="form-label cp-label" for="ConfirmPassword">Confirm Password</label>
                            <div class="cp-control">
                                <span class="cp-control-icon"><i class="fa fa-check-circle"></i></span>
                                @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control", placeholder = "Confirm new password", required = "required" })
                            </div>
                            @Html.ValidationMessageFor(model => model.ConfirmPassword, "", new { @class = "text-danger small" })
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn cp-btn cp-btn-primary" id="btnChangePassword"
                                    data-loading-text="Updating..." data-original-text="Update">
                                <i class="fa fa-refresh"></i>Update
                            </button>
                        </div>
                    }
                </div>
            </div>
        </section>
    </div>

    <style>
        .cp-modern-page {
            --cp-surface: #ffffff;
            --cp-line: #d9e6ea;
            --cp-text: #14323c;
            --cp-muted: #627f8a;
            --cp-brand: var(--color-primary, #0b7d78);
            --cp-brand-soft: #e8f5f3;
            --cp-shadow: 0 14px 30px rgba(17, 42, 48, 0.08);
            color: var(--cp-text);
        }

        .cp-modern-page *,
        .cp-modern-page *::before,
        .cp-modern-page *::after {
            box-sizing: border-box;
        }

        .cp-hero {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 1rem;
            background: linear-gradient(145deg, #effaf8, #edf6fb);
            border: 1px solid #d8e9ec;
            border-radius: 13px;
            padding: 1rem 1.15rem;
            margin-bottom: 1rem;
        }

        .cp-title {
            margin: 0;
            font-size: 1.5rem;
            font-weight: 800;
            letter-spacing: 0.2px;
        }

        .cp-subtitle {
            margin: 0.28rem 0 0;
            font-size: 0.92rem;
            line-height: 1.45;
            color: var(--cp-muted);
        }

        .cp-content-card {
            background: var(--cp-surface);
            border: 1px solid var(--cp-line);
            border-radius: 14px;
            box-shadow: var(--cp-shadow);
            padding: 1rem;
        }

        .cp-label {
            font-size: 0.76rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            color: #56707b;
            margin-bottom: 0.3rem;
        }

        .cp-control {
            display: flex;
            align-items: stretch;
            width: 100%;
            min-width: 0;
            border: 1px solid #cfe0e4;
            border-radius: 10px;
            background: #fff;
            overflow: hidden;
        }

        .cp-control:hover {
            border-color: #bad6dc;
        }

        .cp-control:focus-within {
            border-color: #90c8c4;
            box-shadow: 0 0 0 0.2rem rgba(11, 125, 120, 0.14);
        }

        .cp-control-icon {
            width: 46px;
            min-width: 46px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: var(--cp-brand-soft);
            color: var(--cp-brand);
            border-right: 1px solid #cde2de;
        }

        .cp-control .form-control {
            border: 0;
            border-radius: 0;
            width: 100%;
            min-width: 0;
            height: 44px;
            box-shadow: none;
        }

        .cp-btn {
            min-width: 114px;
            height: 40px;
            border-radius: 10px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.34rem;
            font-size: 0.84rem;
            font-weight: 700;
            border: 1px solid transparent;
            transition: transform 0.15s ease, box-shadow 0.15s ease;
        }

        .cp-btn:hover {
            transform: translateY(-1px);
        }

        .cp-btn:focus-visible {
            outline: none;
            box-shadow: 0 0 0 3px rgba(11, 125, 120, 0.24);
        }

        .cp-btn-primary {
            color: #fff;
            background: var(--cp-brand);
            box-shadow: 0 8px 16px rgba(11, 125, 120, 0.2);
        }

        .cp-btn-primary:hover,
        .cp-btn-primary:focus {
            color: #fff;
        }
    </style>
</div>

@section Scripts{
    <script type="text/javascript">
        $(function () {
            UTILS.activateNavigationLink('settingsLink');
            UTILS.activateMenuNavigationLink('menu-user-password');

            if ($('#menu-learner-password').length) {
                $('#learnerSettingsLink').addClass('active open');
                $('#menu-learner-password').addClass('active');
            }
        });
    </script>
}
